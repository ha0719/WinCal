<Window x:Class="WinCal.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="miniCal 设置"
        Width="420" Height="560"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Border Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            ClipToBounds="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{DynamicResource HoverBrush}">
            <Grid Margin="16,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="⚙ 设置"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />

                <Button Grid.Column="1" x:Name="CloseButton"
                        Width="32" Height="32"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Click="OnCloseClick">
                    <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                          Fill="{DynamicResource TextSecondaryBrush}"
                          Stretch="Uniform" Width="14" Height="14" />
                </Button>
            </Grid>
        </Border>

        <!-- 设置内容区域 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16,20,16">

                <!-- #1 颜色主题 -->
                <TextBlock Text="颜色主题" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8" />
                <ComboBox x:Name="ThemeComboBox" Margin="0,0,0,20" Padding="8,6"
                          SelectedIndex="0">
                    <ComboBoxItem Content="跟随系统" />
                    <ComboBoxItem Content="浅色" />
                    <ComboBoxItem Content="深色" />
                </ComboBox>

                <!-- #2 字体大小 -->
                <TextBlock Text="字体大小" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8" />
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="A" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Slider Grid.Column="1" x:Name="FontSizeSlider"
                            Minimum="-2" Maximum="2" Value="0"
                            TickFrequency="1" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="A" FontSize="17" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                </Grid>
                <TextBlock x:Name="FontSizeLabel" Text="标准"
                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,16" />

                <!-- #3 开机自启动 -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="开机自启动"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                    <CheckBox Grid.Column="1" x:Name="AutoStartupCheckBox"
                              VerticalAlignment="Center" />
                </Grid>

                <!-- #4 日历数据源 -->
                <TextBlock Text="日历数据源" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8" />
                <ComboBox x:Name="DataSourceComboBox" Margin="0,0,0,8" Padding="8,6"
                          SelectedIndex="0" SelectionChanged="OnDataSourceChanged">
                    <ComboBoxItem Content="系统日历" />
                    <ComboBoxItem Content="ICS 订阅链接" />
                    <ComboBoxItem Content="两者都用" />
                </ComboBox>

                <!-- ICS URL 订阅列表 -->
                <StackPanel x:Name="IcsPanel" Visibility="Collapsed" Margin="0,0,0,20">
                    <!-- 已添加的 URL 列表 -->
                    <ItemsControl x:Name="IcsUrlList" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="1"
                                        BorderBrush="{DynamicResource SeparatorBrush}"
                                        CornerRadius="6"
                                        Padding="8,6"
                                        Margin="0,0,0,6">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Grid.Column="0" Width="8" Height="8"
                                                     Fill="{Binding Color}"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,6,0" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DisplayUrl}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                            <Button Grid.Column="2" Content="✕"
                                                    FontSize="11" Width="24" Height="24"
                                                    Padding="0" Margin="4,0,0,0"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand"
                                                    Click="OnRemoveIcsUrl"
                                                    Tag="{Binding Index}" />
                                        </Grid>
                                        <TextBox Text="{Binding Alias, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="11" Padding="4,3" Margin="14,4,0,0"
                                                 ToolTip="为此订阅设置一个显示名称"
                                                 Tag="{Binding Index}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 添加新 URL -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="NewIcsUrlTextBox"
                                 Padding="8,6"
                                 ToolTip="输入 .ics 日历订阅链接" />
                        <Button Grid.Column="1" Content="添加"
                                Padding="12,6" Margin="6,0,0,0"
                                Background="{DynamicResource TodayAccentBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Click="OnAddIcsUrl" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="刷新频率"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" x:Name="IcsRefreshCombo"
                                  Margin="8,0,0,0" Padding="6,4"
                                  SelectedIndex="1" HorizontalAlignment="Left">
                            <ComboBoxItem Content="10 分钟" />
                            <ComboBoxItem Content="30 分钟" />
                            <ComboBoxItem Content="60 分钟" />
                            <ComboBoxItem Content="120 分钟" />
                        </ComboBox>
                    </Grid>
                </StackPanel>

                <!-- #5 近期事件天数 -->
                <TextBlock Text="近期事件显示范围" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8" />
                <ComboBox x:Name="UpcomingDaysCombo" Margin="0,0,0,20" Padding="8,6"
                          SelectedIndex="1">
                    <ComboBoxItem Content="1 天" />
                    <ComboBoxItem Content="3 天" />
                    <ComboBoxItem Content="7 天" />
                </ComboBox>

                <!-- #6 周起始日 -->
                <TextBlock Text="周起始日" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <RadioButton x:Name="WeekStartSunday" Content="周日" Margin="0,0,20,0"
                                 VerticalAlignment="Center" />
                    <RadioButton x:Name="WeekStartMonday" Content="周一"
                                 VerticalAlignment="Center" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- 底部操作栏 -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource SeparatorBrush}"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" x:Name="FooterLink"
                           Text="miniCal v1.0 By www.huangao.net"
                           FontSize="10"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Cursor="Hand"
                           MouseDown="OnFooterLinkClick" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="恢复默认"
                            Padding="12,6" Margin="0,0,8,0"
                            Background="Transparent"
                            BorderBrush="{DynamicResource SeparatorBrush}"
                            BorderThickness="1"
                            Cursor="Hand"
                            Click="OnResetDefaults" />
                    <Button Content="退出程序"
                            Padding="12,6" Margin="0,0,8,0"
                            Background="Transparent"
                            BorderBrush="#FFC62828"
                            Foreground="#FFC62828"
                            BorderThickness="1"
                            Cursor="Hand"
                            Click="OnExitApp" />
                    <Button Content="保存"
                            Padding="20,6"
                            Background="{DynamicResource TodayAccentBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="OnSave" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
    </Border>
</Window>
