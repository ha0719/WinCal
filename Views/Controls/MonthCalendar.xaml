<UserControl x:Class="WinCal.Views.Controls.MonthCalendar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WinCal.Views.Controls">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 月份导航 -->
            <RowDefinition Height="Auto" />  <!-- 星期头 -->
            <RowDefinition Height="Auto" />  <!-- 日历网格 -->
        </Grid.RowDefinitions>

        <!-- 月份导航栏 -->
        <Grid Grid.Row="0" Height="40" Margin="4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 上一月按钮 -->
            <Button Grid.Column="0"
                    x:Name="PrevButton"
                    Content="‹"
                    FontSize="18" FontWeight="Bold"
                    Width="28" Height="28"
                    Background="Transparent"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderThickness="0"
                    Cursor="Hand"
                    VerticalAlignment="Center" />

            <!-- 月份标题 + 今天按钮 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock x:Name="MonthTitle"
                           Text="{Binding MonthDisplay}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
                <Button x:Name="TodayButton"
                        Content="今天"
                        FontSize="11" FontWeight="SemiBold"
                        Padding="6,2"
                        Margin="8,0,0,0"
                        Background="{DynamicResource TodayAccentBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center" />
            </StackPanel>

            <!-- 下一月按钮 -->
            <Button Grid.Column="2"
                    x:Name="NextButton"
                    Content="›"
                    FontSize="18" FontWeight="Bold"
                    Width="28" Height="28"
                    Background="Transparent"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderThickness="0"
                    Cursor="Hand"
                    VerticalAlignment="Center" />
        </Grid>

        <!-- 星期头（动态更新，支持周日起始） -->
        <Grid Grid.Row="1" x:Name="WeekHeaderGrid" Margin="4,0,4,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" x:Name="H0" FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Column="1" x:Name="H1" FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Column="2" x:Name="H2" FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Column="3" x:Name="H3" FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Column="4" x:Name="H4" FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Column="5" x:Name="H5" FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Column="6" x:Name="H6" FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />
        </Grid>

        <!-- 日历网格 (6×7) -->
        <ItemsControl Grid.Row="2" x:Name="CalendarGrid" Margin="2,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="7" Rows="6" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <local:DayCell DayData="{Binding}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
