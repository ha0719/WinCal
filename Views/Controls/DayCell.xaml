<UserControl x:Class="WinCal.Views.Controls.DayCell"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="40" Height="48"
             Cursor="Hand"
             MouseLeftButtonUp="OnDayClick">

    <Grid>
        <!-- 今日高亮圆形背景（缩小，不遮挡农历） -->
        <Ellipse x:Name="TodayCircle"
                 Width="26" Height="26"
                 Fill="{DynamicResource TodayAccentBrush}"
                 Visibility="Collapsed"
                 VerticalAlignment="Top"
                 Margin="0,4,0,0" />

        <!-- 选中日期圆形边框 -->
        <Ellipse x:Name="SelectedCircle"
                 Width="26" Height="26"
                 Stroke="{DynamicResource TodayAccentBrush}"
                 StrokeThickness="1.5"
                 Fill="Transparent"
                 Visibility="Collapsed"
                 VerticalAlignment="Top"
                 Margin="0,4,0,0" />

        <!-- 日期数字 -->
        <TextBlock x:Name="DayText"
                   Text="{Binding DayNumber}"
                   FontSize="13"
                   FontWeight="Normal"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,8,0,0"
                   Foreground="{DynamicResource TextPrimaryBrush}" />

        <!-- 农历文本（可见性由代码后台控制） -->
        <TextBlock x:Name="LunarText"
                   FontSize="8"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,9"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Visibility="Collapsed" />

        <!-- 事件圆点（最多3个，颜色对应事件本身） -->
        <StackPanel x:Name="EventDots"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,2"
                    Visibility="Collapsed">
            <Ellipse x:Name="Dot1" Width="4" Height="4" Margin="1,0" Visibility="Collapsed"/>
            <Ellipse x:Name="Dot2" Width="4" Height="4" Margin="1,0" Visibility="Collapsed"/>
            <Ellipse x:Name="Dot3" Width="4" Height="4" Margin="1,0" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</UserControl>
