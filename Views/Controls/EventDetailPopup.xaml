<Border x:Class="WinCal.Views.Controls.EventDetailPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource CardBackgroundBrush}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="8"
        Padding="12"
        Width="220"
        Visibility="Collapsed">

    <StackPanel>
        <!-- 事件标题 -->
        <TextBlock x:Name="DetailTitle"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8" />

        <!-- 时间 -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock FontSize="11" Text="🕐" Margin="0,0,6,0"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="DetailTime"
                       FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- 地点 -->
        <StackPanel x:Name="LocationPanel"
                    Orientation="Horizontal" Margin="0,0,0,4"
                    Visibility="Collapsed">
            <TextBlock FontSize="11" Text="📍" Margin="0,0,6,0"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="DetailLocation"
                       FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" />
        </StackPanel>

        <!-- 日历来源 -->
        <StackPanel x:Name="CalendarPanel"
                    Orientation="Horizontal" Margin="0,0,0,4"
                    Visibility="Collapsed">
            <TextBlock FontSize="11" Text="📅" Margin="0,0,6,0"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="DetailCalendar"
                       FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- 分隔线 -->
        <Border Height="1"
                Background="{DynamicResource SeparatorBrush}"
                Margin="0,4,0,6" />

        <!-- 描述 -->
        <TextBlock x:Name="DetailDescription"
                   FontSize="11"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap"
                   MaxHeight="80"
                   Visibility="Collapsed" />
    </StackPanel>
</Border>
