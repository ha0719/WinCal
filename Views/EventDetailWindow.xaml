<Window x:Class="WinCal.Views.EventDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EventDetail"
        Width="240" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        MaxHeight="400">

    <Border Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14">

        <StackPanel>
            <!-- 事件标题 -->
            <TextBlock x:Name="DetailTitle"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10" />

            <!-- 时间 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock FontSize="11" Text="🕐" Margin="0,0,6,0"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="DetailTime"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- 地点 -->
            <StackPanel x:Name="LocationPanel"
                        Orientation="Horizontal" Margin="0,0,0,6"
                        Visibility="Collapsed">
                <TextBlock FontSize="11" Text="📍" Margin="0,0,6,0"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="DetailLocation"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- 日历来源 -->
            <StackPanel x:Name="CalendarPanel"
                        Orientation="Horizontal" Margin="0,0,0,6"
                        Visibility="Collapsed">
                <TextBlock FontSize="11" Text="📅" Margin="0,0,6,0"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="DetailCalendar"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- 分隔线 -->
            <Border x:Name="DescSeparator"
                    Height="1"
                    Background="{DynamicResource SeparatorBrush}"
                    Margin="0,4,0,6"
                    Visibility="Collapsed" />

            <!-- 描述 -->
            <TextBlock x:Name="DetailDescription"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       MaxHeight="120"
                       Visibility="Collapsed" />
        </StackPanel>
    </Border>
</Window>
