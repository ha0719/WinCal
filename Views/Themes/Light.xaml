<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 背景色 -->
    <Color x:Key="BackgroundColor">#FFFFFFFF</Color>
    <Color x:Key="CardBackgroundColor">#FFFFFFFF</Color>

    <!-- 强调色 -->
    <Color x:Key="TodayAccentColor">#FF0078D4</Color>

    <!-- 文本色 -->
    <Color x:Key="TextPrimaryColor">#FF1A1A1A</Color>
    <Color x:Key="TextSecondaryColor">#FF767676</Color>
    <Color x:Key="TextDisabledColor">#FFB3B3B3</Color>
    <Color x:Key="TextOnAccentColor">#FFFFFFFF</Color>

    <!-- 分隔与边框 -->
    <Color x:Key="SeparatorColor">#FFE5E5E5</Color>
    <Color x:Key="BorderColor">#FFD4D4D4</Color>

    <!-- 交互状态 -->
    <Color x:Key="HoverColor">#FFF3F3F3</Color>
    <Color x:Key="PressedColor">#FFE8E8E8</Color>
    <Color x:Key="SelectedColor">#FFE0EFFA</Color>

    <!-- 阴影 -->
    <Color x:Key="ShadowColor">#33000000</Color>

    <!-- 事件圆点 -->
    <Color x:Key="EventDotColor">#FF0078D4</Color>

    <!-- 画刷（从颜色派生） -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="TodayAccentBrush" Color="{StaticResource TodayAccentColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}" />
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="{StaticResource TextOnAccentColor}" />
    <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource SeparatorColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}" />
    <SolidColorBrush x:Key="PressedBrush" Color="{StaticResource PressedColor}" />
    <SolidColorBrush x:Key="SelectedBrush" Color="{StaticResource SelectedColor}" />
    <SolidColorBrush x:Key="EventDotBrush" Color="{StaticResource EventDotColor}" />

</ResourceDictionary>
